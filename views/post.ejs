<div class="wrap">
  <article class="post-full">
    <header class="post-header">
      <h1><%= post.title %></h1>
      <div class="post-meta">
        <time><%= post.year %>.<%= post.month %>.<%= post.day %></time>
      </div>
    </header>

    <div class="post-body">
      <%- post.html %>
    </div>

    <nav class="post-near">
      <% if (prev) { %>
        <a href="/post/<%= prev.slug %>" class="near-link">← <%= prev.title %></a>
      <% } else { %>
        <span></span>
      <% } %>
      <% if (next) { %>
        <a href="/post/<%= next.slug %>" class="near-link"><%= next.title %> →</a>
      <% } else { %>
        <span></span>
      <% } %>
    </nav>
  </article>
</div>
